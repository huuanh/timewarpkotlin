<?xml version="1.0" encoding="utf-8"?>
<!-- Large native ad: full media view + icon + headline + body + CTA. Height ~300dp+ -->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1AFFFFFF"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Media view (image/video) -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/adMedia"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop" />

        <!-- Icon + headline row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <ImageView
                android:id="@+id/adIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/adHeadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/adAdvertiser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:maxLines="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/adAttribution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ad"
                android:textSize="9sp"
                android:textColor="#80FFFFFF"
                android:background="#33FFFFFF"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp" />
        </LinearLayout>

        <!-- Body -->
        <TextView
            android:id="@+id/adBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#B0FFFFFF"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginTop="8dp" />

        <!-- Star rating (optional) -->
        <RatingBar
            android:id="@+id/adStarRating"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:isIndicator="true"
            android:numStars="5"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- CTA button -->
        <TextView
            android:id="@+id/adCTA"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="#00CCCC"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp" />

    </LinearLayout>

</com.google.android.gms.ads.nativead.NativeAdView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <!-- Star emoji image overlapping the card top -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="-40dp"
        android:contentDescription="Star"
        android:elevation="2dp"
        android:src="@drawable/ic_star_big" />

    <!-- Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rate_dialog"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="24dp">

        <!-- Close button (top-right) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnCloseRate"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="end"
                android:contentDescription="Close"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_close_clear_cancel" />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Do you like..."
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Share your experience &amp; feedback with us\nWe'd greatly appreciate if you can rate us!"
            android:textColor="#666666"
            android:textSize="14sp" />

        <!-- Stars row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/star1"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:contentDescription="1 star"
                android:src="@drawable/ic_star_filled" />

            <ImageView
                android:id="@+id/star2"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:contentDescription="2 stars"
                android:src="@drawable/ic_star_filled" />

            <ImageView
                android:id="@+id/star3"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:contentDescription="3 stars"
                android:src="@drawable/ic_star_filled" />

            <ImageView
                android:id="@+id/star4"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:contentDescription="4 stars"
                android:src="@drawable/ic_star_filled" />

            <ImageView
                android:id="@+id/star5"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:contentDescription="5 stars"
                android:src="@drawable/ic_star_filled" />

        </LinearLayout>

        <!-- Helper text -->
        <TextView
            android:id="@+id/tvRateHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="The best we can get"
            android:textColor="#999999"
            android:textSize="13sp" />

        <!-- Rate App button -->
        <TextView
            android:id="@+id/btnRateApp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="Rate App"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>

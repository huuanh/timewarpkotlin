<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="NativeAdViewComponent">
        <!-- Whether to show the media view (image/video) -->
        <attr name="showMedia" format="boolean" />
        <!-- Whether to show the advertiser icon -->
        <attr name="showIcon" format="boolean" />
        <!-- Whether to show the call-to-action button -->
        <attr name="showCTA" format="boolean" />
        <!-- Layout style: small, medium, or large -->
        <attr name="adStyle" format="enum">
            <enum name="small" value="0" />
            <enum name="medium" value="1" />
            <enum name="large" value="2" />
        </attr>
    </declare-styleable>
</resources>
